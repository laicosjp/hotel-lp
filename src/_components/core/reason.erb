<section class="reason" id="sec02">
  <p class="deco"><img src="https://images.unsplash.com/photo-1590490360182-c33d57733427?auto=format&fit=crop&w=900&q=80" alt="ホテル客室の落ち着いた内装" width="900" height="600" /></p>

  <div class="wrap">
    <div class="heading">
      <h2>レジャーホテル制作で選ばれる理由</h2>
      <p>Reason</p>
    </div>

    <div class="grid">
      <% items.each do |item| %>
        <article class="item">
          <p class="image"><img src="https://athost.jp/shared/img/<%= item[:image] %>" alt="<%= item[:alt] %>" width="632" height="420" /></p>
          <h3><%= raw item[:title_html] %></h3>
          <p class="text"><%= item[:body] %></p>
        </article>
      <% end %>
    </div>
  </div>
</section>
