<section class="reason" id="reasons">
  <div class="wrap">
    <div class="heading">
      <h2>ホームページ制作で弊社が選ばれる理由</h2>
      <p>Reason</p>
    </div>

    <div class="grid">
      <% items.each do |item| %>
        <article class="item">
          <p class="image"><img src="https://athost.jp/shared/img/<%= item[:image] %>" alt="<%= item[:alt] %>" width="632" height="420" /></p>
          <h3><%= raw item[:title_html] %></h3>
          <p class="text"><%= item[:body] %></p>
        </article>
      <% end %>
    </div>
  </div>
</section>
