<section class="showcase" id="sec07">
  <div class="wrap">
    <div class="section-heading">
      <h2>制作できるページ例</h2>
      <p>Website Contents</p>
    </div>

    <div class="grid">
      <% items.each do |item| %>
        <article class="item">
          <a href="<%= item[:url] %>" target="_blank" rel="noopener">
            <p class="tag"><%= item[:tag] %></p>
            <p class="photo"><img src="<%= item[:image] %>" alt="<%= item[:alt] %>" width="900" height="600" /></p>
            <div class="body">
              <h3><%= item[:title] %></h3>
              <p class="summary"><%= item[:summary] %></p>
              <p class="description"><%= item[:description] %></p>
              <span class="button">サイトを見る</span>
            </div>
          </a>
        </article>
      <% end %>
    </div>
  </div>
</section>
