<section class="feature" id="sec05">
  <div class="intro-row">
    <p class="intro-photo"><img src="https://images.unsplash.com/photo-1551882547-ff40c63fe5fa?auto=format&fit=crop&w=1400&q=80" alt="夜のホテル外観" width="1400" height="900" /></p>
    <div class="intro-content">
      <p class="logo">制作の考え方</p>
      <h2>施設ごとの魅力を、過度に盛らず伝わる形へ</h2>
      <p class="lead">写真、料金、設備、利用シーン、予約導線を一つずつ整理し、<br class="pc" />ホテルの雰囲気と安心感が自然に伝わる公式サイトに整えます。</p>
    </div>
  </div>

  <div class="wrap">
    <% items.each do |item| %>
      <article class="item">
        <p class="photo"><img src="<%= item[:image] %>" alt="<%= item[:alt] %>" width="900" height="650" /></p>
        <div class="content">
          <div class="title-row">
            <p class="number"><%= item[:number] %></p>
            <h3><%= item[:title] %></h3>
          </div>
          <h4><%= item[:summary] %></h4>
          <p class="text"><%= item[:body] %></p>
        </div>
      </article>
    <% end %>
  </div>
</section>
