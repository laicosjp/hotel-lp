<section class="feature" id="features">
  <div class="intro-row">
    <p class="intro-photo"><img src="https://images.unsplash.com/photo-1551882547-ff40c63fe5fa?auto=format&fit=crop&w=1400&q=80" alt="夜のホテル外観" width="1400" height="900" /></p>
    <div class="intro-content">
      <p class="logo">ITで売り上げをアップ</p>
      <h2>ホテルの魅力をきちんと伝える公式サイトへ</h2>
      <p class="lead">部屋の雰囲気、料金、設備、アクセス。<br class="pc" />来店前に見られる情報を整理し、選びやすいホームページを制作します。</p>
    </div>
  </div>

  <div class="wrap">
    <% items.each do |item| %>
      <article class="item">
        <p class="photo"><img src="<%= item[:image] %>" alt="<%= item[:alt] %>" width="900" height="650" /></p>
        <div class="content">
          <div class="title-row">
            <p class="number"><%= item[:number] %></p>
            <h3><%= item[:title] %></h3>
          </div>
          <h4><%= item[:summary] %></h4>
          <p class="text"><%= item[:body] %></p>
        </div>
      </article>
    <% end %>
  </div>
</section>
