<section class="support" id="sec01">
  <div class="wrap">
    <div class="heading">
      <h2>制作・改善できる内容</h2>
      <p>Service</p>
    </div>

    <ul class="grid">
      <% items.each do |item| %>
        <li class="item">
          <img src="https://athost.jp/shared/img/<%= item[:image] %>" alt="<%= item[:name] %>" width="<%= item[:width] %>" height="<%= item[:height] %>" />
          <span><%= item[:name] %></span>
        </li>
      <% end %>
    </ul>

    <h3><span>客室</span>、<span>料金</span>、<span>アクセス</span>、<span>予約導線</span><br class="sp" />を公式サイト上で分かりやすく整えます</h3>
  </div>
</section>
